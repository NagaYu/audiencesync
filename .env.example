# =============================================================================
# AudienceSync — example environment configuration
# Copy to `.env` and fill in. NEVER commit your real `.env` (see .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Source — one of: postgres | mysql | stripe
# -----------------------------------------------------------------------------
SOURCE_KIND=postgres

# Optional: override the extraction SQL. Must return columns:
#   email, phone, first_name, last_name, country, zip
# and accept two bound params for the window: [since, until).
#   Postgres uses $1 / $2 ; MySQL uses ? / ?
# SOURCE_QUERY=SELECT id, email, phone, first_name, last_name, country, zip FROM customers WHERE last_purchase_at >= $1 AND last_purchase_at < $2

# --- Postgres (SOURCE_KIND=postgres) ---
PG_CONNECTION_STRING=postgres://user:password@localhost:5432/app
PG_SSL=true

# --- MySQL (SOURCE_KIND=mysql) ---
# MYSQL_CONNECTION_STRING=mysql://user:password@localhost:3306/app
# MYSQL_SSL=true

# --- Stripe (SOURCE_KIND=stripe) ---
# STRIPE_API_KEY=<your-stripe-secret-key>   # e.g. starts with sk_live_ or sk_test_
# STRIPE_MODE=charges            # charges | customers

# -----------------------------------------------------------------------------
# Window & resilience
# -----------------------------------------------------------------------------
LOOKBACK_HOURS=24                # window when --since/--until are omitted
DEFAULT_COUNTRY=US               # ISO alpha-2 used to add a phone calling code
MAX_RETRIES=4
RETRY_BASE_DELAY_MS=500
DRY_RUN=false

# -----------------------------------------------------------------------------
# Scheduler (used by `audiencesync schedule`)
# -----------------------------------------------------------------------------
CRON_SCHEDULE=0 2 * * *          # every day at 02:00
CRON_TIMEZONE=UTC

# -----------------------------------------------------------------------------
# Destination: Meta Custom Audience
# -----------------------------------------------------------------------------
META_ENABLED=true
META_ACCESS_TOKEN=<your-meta-system-user-token>
META_AUDIENCE_ID=<your-custom-audience-id>
META_API_VERSION=v21.0
META_BATCH_SIZE=1000

# -----------------------------------------------------------------------------
# Destination: Google Customer Match
# Provide EITHER a static GOOGLE_ACCESS_TOKEN, OR (recommended for cron) the
# refresh-token trio so AudienceSync mints a fresh token each run.
# -----------------------------------------------------------------------------
GOOGLE_ENABLED=false
GOOGLE_DEVELOPER_TOKEN=your_developer_token
GOOGLE_CUSTOMER_ID=1234567890
GOOGLE_USER_LIST_RESOURCE_NAME=customers/1234567890/userLists/9876543210
# GOOGLE_LOGIN_CUSTOMER_ID=1112223333   # MCC login id (optional)
GOOGLE_API_VERSION=v17
GOOGLE_BATCH_SIZE=1000

# Option A — static token (expires in ~1h; fine for manual one-shot runs)
# GOOGLE_ACCESS_TOKEN=<your-oauth2-access-token>

# Option B — refresh token (recommended for unattended cron)
# GOOGLE_REFRESH_TOKEN=<your-refresh-token>
# GOOGLE_CLIENT_ID=<your-client-id>.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=<your-google-client-secret>
